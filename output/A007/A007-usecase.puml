@startuml A007-usecase
left to right direction
skinparam actorStyle awesome

actor "系統管理員" as Admin

rectangle "管理員管理供應商" {
    usecase "查詢供應商清單（精確查詢）" as UC1
    usecase "查詢供應商清單（模糊查詢）" as UC2
    usecase "查詢單一供應商詳細資料" as UC3
    usecase "修改供應商資料" as UC4
    usecase "驗證欄位格式" as UC5
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4

UC4 ..> UC5 : <<include>>
@enduml
