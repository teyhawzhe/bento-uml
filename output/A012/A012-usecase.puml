@startuml A012-usecase
left to right direction
skinparam actorStyle awesome

actor "系統管理員" as Admin

rectangle "A012 CSV 批次匯入管理" {
    usecase "下載員工 CSV 範本" as UC1
    usecase "下載部門 CSV 範本" as UC2
    usecase "下載供應商 CSV 範本" as UC3
    usecase "下載便當菜單 CSV 範本" as UC4
    usecase "批次匯入員工 CSV" as UC5
    usecase "批次匯入部門 CSV" as UC6
    usecase "批次匯入供應商 CSV" as UC7
    usecase "批次匯入便當菜單 CSV" as UC8
    usecase "驗證 CSV 表頭" as UC9
    usecase "驗證欄位完整性與重複資料" as UC10
    usecase "查看匯入成功資料清單" as UC11
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC11

UC5 .> UC9 : <<include>>
UC6 .> UC9 : <<include>>
UC7 .> UC9 : <<include>>
UC8 .> UC9 : <<include>>

UC5 .> UC10 : <<include>>
UC6 .> UC10 : <<include>>
UC7 .> UC10 : <<include>>
UC8 .> UC10 : <<include>>

UC5 .> UC11 : <<extend>>
UC6 .> UC11 : <<extend>>
UC7 .> UC11 : <<extend>>
UC8 .> UC11 : <<extend>>

@enduml
