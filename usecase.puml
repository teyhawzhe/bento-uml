@startuml usecase-overview
left to right direction
skinparam actorStyle awesome

actor "員工" as Employee
actor "系統管理員" as Admin
actor "系統（排程）" as Scheduler

rectangle "A001 內部員工登入驗證" {
    usecase "員工登入" as A001_UC1
    usecase "查看錯誤訊息" as A001_UC2
    usecase "登出系統" as A001_UC3
    usecase "忘記密碼" as A001_UC4
    usecase "修改密碼" as A001_UC5
    usecase "管理員登入" as A001_UC6
    usecase "查詢員工清單" as A001_UC11
    usecase "新增員工帳號" as A001_UC7
    usecase "CSV 批次匯入員工帳號" as A001_UC10
    usecase "停用員工帳號" as A001_UC8
    usecase "啟用員工帳號" as A001_UC12
    usecase "重設員工密碼（Email 通知）" as A001_UC9
}

rectangle "A002 員工訂便當" {
    usecase "瀏覽下週便當選項" as A002_UC1
