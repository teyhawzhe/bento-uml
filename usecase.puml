    usecase "取消指定員工的訂餐" as A002_UC7
}

rectangle "A003 每日供應商訂單通知" {
    usecase "每日自動執行排程" as A003_UC1
    usecase "彙整各供應商隔日訂單" as A003_UC2
    usecase "發送 Email 通知供應商" as A003_UC3
    usecase "發送錯誤通知至管理員信箱" as A003_UC4
    usecase "記錄發送結果" as A003_UC5
}

rectangle "A004 系統錯誤通知信箱設定" {
    usecase "查詢錯誤通知信箱清單" as A004_UC1
